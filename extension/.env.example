# =============================================================================
# Shopii Extension — Environment Variables
# Copy this file to .env and fill in the values.
#
# NOTE: All VITE_ prefixed variables are embedded into the extension build.
# Do NOT put secret keys here — only public/anon keys.
# =============================================================================

# API server URL (the Shopii backend)
VITE_API_URL=http://localhost:3001

# Supabase (public/anon key only — never put service role key here)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Whisper Flow API Key for voice transcription (optional)
# VITE_WHISPER_FLOW_API_KEY=your-whisper-flow-api-key
