# =============================================================================
# Shopii Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values before running docker-compose.
# =============================================================================

# ---------- Infrastructure ----------
POSTGRES_PASSWORD=          # Strong password for PostgreSQL
API_PORT=3001               # Host port to expose the API on

# ---------- Supabase (REQUIRED) ----------
SUPABASE_URL=               # https://your-project.supabase.co
SUPABASE_ANON_KEY=          # anon/public key
SUPABASE_SERVICE_ROLE_KEY=  # service role key (keep secret)

# ---------- AI Providers (at least one required for chat) ----------
OPENAI_API_KEY=             # GPT-4o-mini for chat
ANTHROPIC_API_KEY=          # Claude for chat + scraper analysis

# ---------- AI Providers (optional) ----------
GEMINI_API_KEY=             # Gemini for chat (fallback)
TAVILY_API_KEY=             # Tavily for product search
GOOGLE_API_KEY=             # Google Custom Search
GOOGLE_CX=                  # Google Custom Search Engine ID
FIRECRAWL_API_KEY=          # Firecrawl for web scraping

# ---------- Stripe (optional — billing features) ----------
STRIPE_SECRET_KEY=          # sk_live_...
STRIPE_WEBHOOK_SECRET=      # whsec_...
STRIPE_PRO_PRICE_ID=        # price_...

# ---------- Chrome Extension ----------
CHROME_EXTENSION_ID=        # Restrict CORS to your published extension ID

# ---------- Scraper (optional) ----------
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
YOUTUBE_API_KEY=
