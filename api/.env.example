# =============================================================================
# Shopii API — Environment Variables
# Copy this file to .env and fill in the values.
# =============================================================================

# Server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# Database
# For local dev with SQLite: file:./prisma/dev.db
# For production/remote: postgresql://user:pass@host:5432/dbname
DATABASE_URL=file:./prisma/dev.db

# Redis (required for rate limiting in production, uses in-memory mock in dev)
REDIS_URL=redis://localhost:6379

# --- Authentication (Supabase) ---
# Required for production. In dev mode, mock auth is used if these are empty.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --- AI Providers (at least one required for chat) ---
OPENAI_API_KEY=sk-proj-your-key
ANTHROPIC_API_KEY=sk-ant-your-key
# GEMINI_API_KEY=your-gemini-key

# --- Research & Search ---
# Tavily — used for product research from Reddit/forums (required for search mode)
TAVILY_API_KEY=tvly-your-key

# Google Custom Search (optional — used as supplemental product URL lookup)
# GOOGLE_API_KEY=AIza-your-key
# GOOGLE_CX=your-search-engine-id

# --- Web Scraping ---
# Firecrawl — fallback for JS-rendered product pages (optional)
# FIRECRAWL_API_KEY=fc-your-key

# --- Payments (Stripe) ---
# Optional in dev. Required for billing in production.
# STRIPE_SECRET_KEY=sk_test_your-key
# STRIPE_WEBHOOK_SECRET=whsec_your-key
# STRIPE_PRO_PRICE_ID=price_your-price-id

# --- Affiliate ---
AMAZON_AFFILIATE_TAG=shopii-20

# --- Security / CORS ---
CORS_ORIGIN=chrome-extension://*

# Chrome Extension ID — set in production to restrict CORS to your published extension only
# CHROME_EXTENSION_ID=abcdefghijklmnopqrstuvwxyz
